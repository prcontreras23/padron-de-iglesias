{
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/solicitud", "destination": "/solicitud/index.html" },
    { "source": "/solicitud/", "destination": "/solicitud/index.html" },
    { "source": "/nueva-congregacion", "destination": "/nueva-congregacion/index.html" },
    { "source": "/nueva-congregacion/", "destination": "/nueva-congregacion/index.html" },
    { "source": "/permiso-ausencia", "destination": "/permiso-ausencia/index.html" },
    { "source": "/permiso-ausencia/", "destination": "/permiso-ausencia/index.html" },
    { "source": "/portal", "destination": "/portal/index.html" },
    { "source": "/portal/", "destination": "/portal/index.html" },
    { "source": "/(.*)", "destination": "/$1" }
  ]
}
